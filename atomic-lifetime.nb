Cell["Estimator", "Subsection",
 FontSize->18,ExpressionUUID->"231c1020-600f-460b-bb0a-210de780bb42"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"\[Theta]k1locProb", ",", "\[Theta]k2locProb"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]k1locProb", "[", "x_", "]"}], ":=", 
  RowBox[{"\[Theta]u", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"NIntegrate", "[", 
