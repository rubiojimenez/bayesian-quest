      RowBox[{
       RowBox[{"p", " ", 
        RowBox[{"Tr", "[", 
         RowBox[{
          RowBox[{"locPOM2", "[", "x", "]"}], ".", 
          FormBox["\[Rho]",
           TraditionalForm]}], "]"}], 
        RowBox[{"Log", "[", 
         RowBox[{"\[Theta]", "/", "\[Theta]u"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "\[Theta]min", ",", "\[Theta]max"}], "}"}]}],
       "]"}], "/", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{"p", " ", 
        RowBox[{"Tr", "[", 
         RowBox[{
          RowBox[{"locPOM2", "[", "x", "]"}], ".", 
          FormBox["\[Rho]",
           TraditionalForm]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "\[Theta]min", ",", "\[Theta]max"}], "}"}]}],
       "]"}]}], "]"}]}]}]}], "Input",
