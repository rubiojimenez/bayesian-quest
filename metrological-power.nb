Cell[CellGroupData[{

Cell["Reparametrised metrological power ", "Subsection",
 FontSize->18,ExpressionUUID->"632763e5-7e75-48ee-846b-822dfcab0f43"],

Cell["\<\
The metrological power of each state is here reparametrised in terms of the \
average number of such state. In addition, the prior width is taken as W = \
a/M, where \[OpenCurlyQuote]a\[CloseCurlyQuote] is a constsant.\
\>", "Text",ExpressionUUID->"962d6343-c91d-41a8-8fbb-53259d7b627b"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{
  "AvgNumBayesPowerA", ",", "AvgNumBayesPowerB", ",", "AvgNumBayesPowerC", ",",
    "a"}], "]"}]], "Input",
 CellLabel->
  "In[196]:=",ExpressionUUID->"923ad0ba-bcc8-49f2-bb05-cc8606cf2704"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"AvgNumBayesInfoA", "[", 
    RowBox[{"W_", ",", "\[Eta]_", ",", "M_"}], "]"}], "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"BayesPowerA", "[", 
     RowBox[{
      RowBox[{"a", "/", "M"}], ",", "\[Eta]", ",", 
      RowBox[{"nbarA", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", 
          RowBox[{"\[Eta]", "^", "2"}]}], ")"}]}]}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AvgNumBayesInfoB", "[", 
    RowBox[{"W_", ",", "\[Eta]_", ",", "M_"}], "]"}], "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"BayesPowerB", "[", 
     RowBox[{
      RowBox[{"a", "/", "M"}], ",", "\[Eta]", ",", 
      RowBox[{"nbarB", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", 
          RowBox[{"\[Eta]", "^", "2"}]}], ")"}]}]}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AvgNumBayesInfoC", "[", 
    RowBox[{"W_", ",", "M_"}], "]"}], "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"BayesPowerC", "[", 
     RowBox[{
      RowBox[{"a", "/", "M"}], ",", "M"}], "]"}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[197]:=",ExpressionUUID->"2b809a11-a9db-47a5-84e7-a6e290200669"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"AvgNumBayesInfoA", "[", 
   RowBox[{"W", ",", "\[Eta]", ",", 
    RowBox[{"nbar", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", 
        RowBox[{"\[Eta]", "^", "2"}]}], ")"}]}]}]}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[200]:=",ExpressionUUID->"2f704511-a482-45f4-b8f2-9798c2f0f980"],

Cell[BoxData[
 FractionBox[
  RowBox[{"72", " ", 
   SuperscriptBox["nbar", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Cos", "[", 
        FractionBox["a", "2"], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Sin", "[", 
        FractionBox["a", "2"], "]"}]}]}], ")"}], "2"]}], 
  RowBox[{
   SuperscriptBox["a", "6"], " ", 
   SuperscriptBox["\[Eta]", "2"]}]]], "Output",
 CellLabel->
  "Out[200]=",ExpressionUUID->"0219aa75-6885-4001-bf8b-8c76a9b167d8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"AvgNumBayesInfoB", "[", 
   RowBox[{"W", ",", "\[Eta]", ",", 
    RowBox[{"nbar", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "^", "2"}], "/", 
