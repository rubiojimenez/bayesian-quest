Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"\[Rho]Azeroth", ",", "CmatA", ",", "\[Rho]AzerothDiag"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]Azeroth", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"p", " ", "\[Rho]A"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Phi]", ",", "a", ",", "b"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "\[Rho]Azeroth", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"CmatA", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"Transpose", "[", 
      RowBox[{"Eigenvectors", "[", "\[Rho]Azeroth", "]"}], "]"}], "]"}]}], 
   ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{"\[Rho]AzerothDiag", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Inverse", "[", "CmatA", "]"}], ".", "\[Rho]Azeroth", ".", 
     "CmatA"}], "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[132]:=",ExpressionUUID->"fd4396ae-9566-4126-add3-3f013a9aff62"],

