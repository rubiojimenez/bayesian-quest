Cell[CellGroupData[{

Cell["A different constraint on the photon number distribution", "Section",
 FontSize->24,ExpressionUUID->"63847c01-6505-4591-a91a-6ea664a39555"],

Cell[CellGroupData[{

Cell["Measure of \[OpenCurlyQuote]photon number \
fluctuations\[CloseCurlyQuote] around zero", "Subsection",
 FontSize->18,ExpressionUUID->"8fa06c33-f711-48ac-aa31-5585c472a056"],

Cell[TextData[{
 "Defined as: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Tr", "(", 
    SuperscriptBox["\[Rho]N", "2"]}], TraditionalForm]],ExpressionUUID->
  "9823fd0b-f06c-4b1f-86a4-4fb30c5a1b8e"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox[")", 
    RowBox[{"1", "/", "2"}]], TraditionalForm]],ExpressionUUID->
  "7b1fe51e-1bfd-4e84-bd0f-035ac2ed282b"],
 ", where N is a sum of number operators, t",
 "hat is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["N",
     FontSlant->"Plain"], "=", 
    RowBox[{
     SubscriptBox["N", "1"], " ", "+", 
     SubscriptBox["N", "2"]}]}], TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"8e3adf13-08e8-4f62-858c-886ec445d403"],
 " (on",
 "e per arm of the interferometer)."
}], "Text",ExpressionUUID->"5b9e4301-b213-40e8-9df9-3c63cbed9907"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"nbar2A", ",", "nbar2B", ",", "nbar2C"}], "]"}]], "Input",
 CellLabel->
  "In[203]:=",ExpressionUUID->"fc6587a0-6c33-4ee2-9e77-dff4a511603b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nbar2A", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"Tr", "[", 
      RowBox[{"\[Rho]A", ".", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"M", "^", "2"}], ",", 
          RowBox[{"M", "^", "2"}], ",", 
          RowBox[{"4", 
           RowBox[{"M", "^", "2"}]}]}], " ", "}"}], "]"}]}], "]"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nbar2B", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"Tr", "[", 
      RowBox[{"\[Rho]B", ".", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"M", "^", "2"}], ",", 
          RowBox[{"M", "^", "2"}]}], "}"}], "]"}]}], "]"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nbar2C", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"Tr", "[", 
      RowBox[{"\[Rho]C", ".", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"M", "^", "2"}], ",", 
          RowBox[{"M", "^", "2"}]}], " ", "}"}], "]"}]}], "]"}], "]"}], 
    "]"}]}], ";"}]}], "Input",
 CellLabel->
  "In[204]:=",ExpressionUUID->"ba3b9dbd-d65d-4e82-92b0-22e3bbd01fd6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Reparametrised metrological power", "Subsection",
 FontSize->18,ExpressionUUID->"5c25fa4c-3268-4cec-80bb-d9ac6b58d541"],

Cell["\<\
The metrological power of each state is here reparametrised in terms of the \
\[OpenCurlyQuote]photon number fluctuations\[CloseCurlyQuote] of such state \
around zero. In addition, the prior width is taken as W = a/M, where \
\[OpenCurlyQuote]a\[CloseCurlyQuote] is a constsant.\
\>", "Text",ExpressionUUID->"7521c625-b20b-4ed8-b97a-c71a05fa9796"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{
  "FlucBayesPowerA", ",", "FlucBayesPowerB", ",", "FlucBayesPowerC", ",", 
   "a"}], "]"}]], "Input",
 CellLabel->
  "In[207]:=",ExpressionUUID->"ca5c89da-5f7c-4185-9af0-0c8c994052dc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"FlucBayesInfoA", "[", 
    RowBox[{"W_", ",", "\[Eta]_", ",", "M_"}], "]"}], "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"BayesPowerA", "[", 
     RowBox[{
      RowBox[{"a", "/", "M"}], ",", "\[Eta]", ",", 
      RowBox[{"nbar2A", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Eta]", "^", "2"}], "+", 
             RowBox[{"2", 
              RowBox[{"\[Eta]", "^", "4"}]}]}], ")"}]}], ")"}]}], "]"}]}]}], 
     "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FlucBayesInfoB", "[", 
    RowBox[{"W_", ",", "\[Eta]_", ",", "M_"}], "]"}], "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"BayesPowerB", "[", 
     RowBox[{
      RowBox[{"a", "/", "M"}], ",", "\[Eta]", ",", 
      RowBox[{"nbar2B", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "^", "2"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", 
           RowBox[{"\[Eta]", "^", "2"}]}], ")"}]}], "]"}]}]}], "]"}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FlucBayesInfoC", "[", 
    RowBox[{"W_", ",", "M_"}], "]"}], "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"BayesPowerC", "[", 
     RowBox[{
      RowBox[{"a", "/", "M"}], ",", "nbarC"}], "]"}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->
  "In[208]:=",ExpressionUUID->"f538c447-96a9-41c4-93bc-9e21c4f63006"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"AvgNumBayesInfoA", "[", 
   RowBox[{"W", ",", "\[Eta]", ",", 
    RowBox[{"nbar2", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Eta]", "^", "2"}], "+", 
           RowBox[{"2", 
            RowBox[{"\[Eta]", "^", "4"}]}]}], ")"}]}], ")"}]}], "]"}]}]}], 
   "]"}], "]"}]], "Input",
 CellLabel->
  "In[211]:=",ExpressionUUID->"976213dc-e455-4d0f-8bf8-f0dee3253178"],

Cell[BoxData[
 FractionBox[
  RowBox[{"144", " ", 
   SuperscriptBox["nbar2", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Cos", "[", 
        FractionBox["a", "2"], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Sin", "[", 
        FractionBox["a", "2"], "]"}]}]}], ")"}], "2"]}], 
  RowBox[{
   SuperscriptBox["a", "6"], " ", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["\[Eta]", "2"]}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox["\[Eta]", "4"]}]}], ")"}]}]]], "Output",
 CellLabel->
  "Out[211]=",ExpressionUUID->"f42e9e90-b67b-4be9-ac55-b07c28d229b4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"AvgNumBayesInfoB", "[", 
   RowBox[{"W", ",", "\[Eta]", ",", 
    RowBox[{"nbar2", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "^", "2"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", 
         RowBox[{"\[Eta]", "^", "2"}]}], ")"}]}], "]"}]}]}], "]"}], 
  "]"}]], "Input",
 CellLabel->
  "In[212]:=",ExpressionUUID->"fbd9e042-7ed0-43e9-af62-aff743f2a106"],

Cell[BoxData[
 FractionBox[
  RowBox[{"144", " ", 
   SuperscriptBox["nbar2", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Cos", "[", 
        FractionBox["a", "2"], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Sin", "[", 
        FractionBox["a", "2"], "]"}]}]}], ")"}], "2"]}], 
  SuperscriptBox["a", "6"]]], "Output",
 CellLabel->
  "Out[212]=",ExpressionUUID->"8c1467a9-83ff-486e-84e9-c64d25ee7ffb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"AvgNumBayesInfoC", "[", 
   RowBox[{"W", ",", "nbar2"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[213]:=",ExpressionUUID->"7204da10-25f6-431c-9f38-794f1665a1c2"],

Cell[BoxData[
 FractionBox[
  RowBox[{"144", " ", 
   SuperscriptBox["nbar2", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Cos", "[", 
        FractionBox["a", "2"], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Sin", "[", 
        FractionBox["a", "2"], "]"}]}]}], ")"}], "2"]}], 
  SuperscriptBox["a", "6"]]], "Output",
 CellLabel->
  "Out[213]=",ExpressionUUID->"42939317-976f-4351-afe3-9665c0ba5669"]
}, Open  ]],

Cell["\<\
We then see how by using \[OpenCurlyQuote]photon number fluctuations\
\[CloseCurlyQuote] around zero as the resource the three states are full \
equivalent. This however hides the potential damage in noninformative events, \
which in turn suggests that one should choose the metric for resources \
depending on the application in at hand.\
\>", "Text",ExpressionUUID->"ac195a9b-4943-4a7f-b45c-5709a851111e"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
