Cell["Basis for state C: {|M,0>, |0,M>}", "Text",ExpressionUUID->"04d43e23-9125-4a90-acad-c1cd4c194616"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"\[Psi]C", ",", "\[Rho]C", ",", "\[Phi]", ",", "M"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Psi]C", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], " ", "M", " ", 
          RowBox[{"\[Phi]", "/", "2"}]}], "]"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "M", " ", 
          RowBox[{"\[Phi]", "/", "2"}]}], "]"}], "}"}]}], "}"}], "/", 
     RowBox[{"Sqrt", "[", "2", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]C", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{
       RowBox[{"ConjugateTranspose", "[", "\[Psi]C", "]"}], ",", "\[Psi]C"}], 
      "]"}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Element", "[", 
         RowBox[{"M", ",", "Reals"}], "]"}], ",", 
        RowBox[{"Element", "[", 
         RowBox[{"\[Phi]", ",", "Reals"}], "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "\[Rho]C", "]"}]}], "Input",
 CellLabel->
  "In[128]:=",ExpressionUUID->"b8c7742b-dc30-4dbd-84bf-0344d9aa2742"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["1", "2"], 
      RowBox[{
       FractionBox["1", "2"], " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", "M", " ", "\[Phi]"}]]}]},
     {
      RowBox[{
       FractionBox["1", "2"], " ", 
