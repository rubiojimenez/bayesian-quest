          RowBox[{"locPOM1", "[", "x", "]"}], ".", 
          FormBox["\[Rho]",
           TraditionalForm]}], "]"}], 
        RowBox[{"Log", "[", 
         RowBox[{"\[Theta]", "/", "\[Theta]u"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "\[Theta]min", ",", "\[Theta]max"}], "}"}]}],
       "]"}], "/", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{"p", " ", 
        RowBox[{"Tr", "[", 
         RowBox[{
          RowBox[{"locPOM1", "[", "x", "]"}], ".", 
          FormBox["\[Rho]",
           TraditionalForm]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "\[Theta]min", ",", "\[Theta]max"}], "}"}]}],
       "]"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]k2locProb", "[", "x_", "]"}], ":=", 
  RowBox[{"\[Theta]u", " ", 
