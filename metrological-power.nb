 FractionBox[
  RowBox[{"144", " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"M", " ", "W", " ", 
       RowBox[{"Cos", "[", 
        FractionBox[
         RowBox[{"M", " ", "W"}], "2"], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Sin", "[", 
        FractionBox[
         RowBox[{"M", " ", "W"}], "2"], "]"}]}]}], ")"}], "2"]}], 
  RowBox[{
   SuperscriptBox["M", "4"], " ", 
   SuperscriptBox["W", "6"]}]]], "Output",
 CellLabel->
