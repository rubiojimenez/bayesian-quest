    3.8355429121001053`*^9}, {3.8355429519996758`*^9, 
    3.8355429541515107`*^9}, {3.8355430082472153`*^9, 3.835543198011278*^9}, {
    3.835543259787874*^9, 3.8355433236326246`*^9}, {3.835543388665143*^9, 
