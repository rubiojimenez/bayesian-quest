    RowBox[{"BayesPowerC", "[", 
     RowBox[{"W", ",", "M"}], "]"}], "/", 
    RowBox[{"pSomethingC", "[", "M", "]"}]}], "]"}]}]], "Input",
 CellLabel->
  "In[191]:=",ExpressionUUID->"788f61f4-24d4-467a-9248-cff66f93f781"],

