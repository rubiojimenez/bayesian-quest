Notebook[{

Cell[CellGroupData[{
Cell["\<\
Metrological power in quantum interferometry with finite information\
\>", "Title",
 FontSize->36,ExpressionUUID->"767000d7-785a-403a-8259-7ce916f377d8"],

Cell[TextData[{
 StyleBox["Dr Jes\[UAcute]s Rubio",
  FontWeight->"Bold",
  FontColor->GrayLevel[0.5]],
 StyleBox["\nDepartment of Physics and Astronomy, University of Exeter\nORCID \
iD: ",
  FontColor->GrayLevel[0.5]],
 StyleBox[ButtonBox["0000-0002-8193-8273",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://orcid.org/0000-0002-8193-8273"], None},
  ButtonNote->"https://orcid.org/0000-0002-8193-8273"],
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.25098039215686274`, 0.5019607843137255]],
 "\n\nThe calculations in this notebook correspond to Sec. V and App. A.2 of \
\n\n\tD. Branford and J. Rubio, ",
 StyleBox["Average number is an insufficient metric for interferometry,",
  FontSlant->"Italic"],
 " ",
 StyleBox[ButtonBox["New J. Phys. 23 123041",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://iopscience.iop.org/article/10.1088/1367-2630/ab098b"], None},
  ButtonNote->"https://iopscience.iop.org/article/10.1088/1367-2630/ab098b"],
  FontWeight->"Bold"],
 " (2021)\n\nStates considered:\n\n\tA) general state spanned over {|0,0>, \
|0,M>, |M,0>, |M,M>}\n\tB) Mixed N00N state\n\tC) N00N state\n\nRemarks:\n\n\t\
- The system is assumed to be a Mach-Zehnder interferometer with no reference \
beam\n\t- The quantifier for metrological power employed here is only valid \
for a regime with moderate prior information (given a flat prior of width W, \
such W needs be less than or similar to 2)\n\t- All results are for a single \
shot and using the mean square error criterion\n\t- The calculation of the \
optimal quantum operators follows Eq. (B10) of \n\t\n\t\tJ. Rubio and J. \
Dunningham, ",
 StyleBox["Quantum metrology in the presence of limited data",
  FontSlant->"Italic"],
 ", ",
 StyleBox[ButtonBox["New J. Phys. 21 043037",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://iopscience.iop.org/article/10.1088/1367-2630/ab098b"], None},
  ButtonNote->"https://iopscience.iop.org/article/10.1088/1367-2630/ab098b"],
  FontWeight->"Bold"],
 " (2019)\n\n",
 StyleBox["Created",
  FontWeight->"Bold"],
 ": December 2020"
}], "Text",ExpressionUUID->"a03051b2-2b03-4276-b16a-9e3d90437730"],

Cell[CellGroupData[{

Cell["Calculating the metrological power of states A, B and C", "Section",
 FontSize->24,ExpressionUUID->"74549090-f68b-47b6-acbc-910ca3bf395a"],

Cell[CellGroupData[{

Cell["Prior probability", "Subsection",
 FontSize->18,ExpressionUUID->"134ecbef-2767-4da9-8220-3c2c8a245531"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"p", ",", "a", ",", "b", ",", "W"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "=", 
   RowBox[{
    RowBox[{"-", "W"}], "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", 
   RowBox[{"W", "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p", "=", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"b", "-", "a"}], ")"}]}]}], ";"}]}], "Input",
 CellLabel->
  "In[118]:=",ExpressionUUID->"26e2b967-9acc-4da8-bbff-c142cf2213e7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Probe states (with dependency on the difference of phase shifts)\
\>", "Subsection",
 FontSize->18,ExpressionUUID->"39df1cf5-81b2-4abf-9855-8dae42055d50"],

Cell["Basis for state A: {|0,0>, |M,0>, |0,M>, |M,M>}", "Text",ExpressionUUID->"26f372de-9c31-4d9e-8bd2-0aacf5e07a60"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"\[Rho]A", ",", "\[Phi]", ",", "\[Eta]", ",", "M"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]A", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"\[Eta]", "^", "2"}], ",", 
          RowBox[{
           RowBox[{"\[Eta]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "M", " ", "\[Phi]"}], "]"}]}], ",", 
          "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{
           RowBox[{"\[Eta]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "M", " ", "\[Phi]"}], "]"}]}], ",", 
          RowBox[{"\[Eta]", "^", "2"}], ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0", ",", 
          RowBox[{"\[Eta]", "^", "4"}]}], "}"}]}], "}"}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Eta]", "^", "2"}]}], ")"}], "^", "2"}]}], ",", 
     RowBox[{"Assumptions", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Element", "[", 
         RowBox[{"\[Eta]", ",", "Reals"}], "]"}], ",", 
        RowBox[{"Element", "[", 
         RowBox[{"M", ",", "Integers"}], "]"}], ",", 
        RowBox[{"Element", "[", 
         RowBox[{"\[Phi]", ",", "Reals"}], "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "\[Rho]A", "]"}]}], "Input",
 CellLabel->
  "In[122]:=",ExpressionUUID->"0706d23d-47fb-4480-a774-e195135366e1"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["1", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[Eta]", "2"]}], ")"}], "2"]], "0", "0", "0"},
     {"0", 
      FractionBox[
       SuperscriptBox["\[Eta]", "2"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[Eta]", "2"]}], ")"}], "2"]], 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", "M", " ", "\[Phi]"}]], " ", 
        SuperscriptBox["\[Eta]", "2"]}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[Eta]", "2"]}], ")"}], "2"]], "0"},
     {"0", 
      FractionBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "M", " ", "\[Phi]"}]], " ", 
        SuperscriptBox["\[Eta]", "2"]}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[Eta]", "2"]}], ")"}], "2"]], 
      FractionBox[
       SuperscriptBox["\[Eta]", "2"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[Eta]", "2"]}], ")"}], "2"]], "0"},
     {"0", "0", "0", 
      FractionBox[
       SuperscriptBox["\[Eta]", "4"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[Eta]", "2"]}], ")"}], "2"]]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
