 FractionBox[
  RowBox[{"72", " ", 
   SuperscriptBox["nbar", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["\[Eta]", "2"]}], ")"}], "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Cos", "[", 
        FractionBox["a", "2"], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Sin", "[", 
        FractionBox["a", "2"], "]"}]}]}], ")"}], "2"]}], 
  RowBox[{
   SuperscriptBox["a", "6"], " ", 
   SuperscriptBox["\[Eta]", "2"]}]]], "Output",
 CellLabel->
  "Out[201]=",ExpressionUUID->"086f0560-8839-4c62-85e2-0d7d158c919e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{"AvgNumBayesInfoC", "[", 
   RowBox[{"W", ",", "nbar"}], "]"}], "]"}]], "Input",
 CellLabel->
  "In[202]:=",ExpressionUUID->"26237bdf-d875-4c09-bcb1-6c0fe4d67b2e"],

Cell[BoxData[
 FractionBox[
  RowBox[{"144", " ", 
   SuperscriptBox["nbar", "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"a", " ", 
       RowBox[{"Cos", "[", 
        FractionBox["a", "2"], "]"}]}], "-", 
      RowBox[{"2", " ", 
       RowBox[{"Sin", "[", 
        FractionBox["a", "2"], "]"}]}]}], ")"}], "2"]}], 
  SuperscriptBox["a", "6"]]], "Output",
 CellLabel->
  "Out[202]=",ExpressionUUID->"fb23e1c9-73f4-413a-8864-5e1916730da7"]
}, Open  ]],

Cell[BoxData[Cell[TextData[{
  "The apparent \[OpenCurlyQuote]infinite precision\[CloseCurlyQuote] of \
states A and B is explained away by noticing that sending \[Eta] to 0 implies \
that M goes to infinity.  That is, such states require us to hold perfect \
initial knowledge, so that not real gain can be achieved by running the \
experiment. \nNote, however, that by solving the paradox in this way one then \
hides the fact that average number can be decoupled from the metrological \
power of a given state. See Ref.  ",
  Cell[BoxData[
   StyleBox[
    ButtonBox[
     RowBox[{"arXiv", ":", "2107.06698"}],
     BaseStyle->"Hyperlink",
     ButtonData->{
       URL["https://arxiv.org/abs/2107.06698"], None},
     ButtonNote->"https://arxiv.org/abs/2107.06698"],
    FontWeight->"Bold"]],
   CellChangeTimes->{{3.826893900119753*^9, 3.826894056264826*^9}, 
     3.8268941312224045`*^9, {3.8355483958180223`*^9, 
     3.8355484781539516`*^9}, {3.8355485575211215`*^9, 
     3.835548603345049*^9}, {3.8355486370210285`*^9, 3.835548664036238*^9}},
   FontSize->14,ExpressionUUID->"a0a644cb-7185-47f8-bc9c-2e0edcd6c976"],
  "."
 }], "Text",
  CellChangeTimes->{{3.8172308876435714`*^9, 3.817231007939225*^9}, {
